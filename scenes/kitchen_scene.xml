<mujoco model="reachy2_kitchen_scene">
    <compiler angle="radian"/>

    <include file="../assets/reachy2_asset.xml"/>
    <include file="../assets/kitchen2_asset.xml"/>
    <include file="../assets/table_asset.xml"/>
    <include file="../assets/fork_asset.xml"/>
    <include file="../assets/knife_asset.xml"/>
    <include file="../assets/plate_asset.xml"/>
    <include file="../assets/cup_asset.xml"/>

    <asset>
		<texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
		<texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
		<material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
	</asset>

    <default>
        <default class="ycb_col">
            <geom contype="1" rgba = "1 1 1 1" conaffinity="1" condim ="6" solimp="0.95 0.99 0.001" solref=".002 1" margin = "0.002" friction="0.5 0.1 0.01" group = "3"/>
        </default>
        <default class="ycb_viz">
            <geom contype="0" conaffinity="0" type="mesh"/>
        </default>
    </default>

    <option gravity="0 0 -9.81" timestep="0.001" iterations="50" integrator="implicitfast">
        <flag multiccd="enable" contact="enable"/>
    </option>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.5 0.5 0.5" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="160" elevation="-20" offwidth="1280" offheight="720"/>
    </visual>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="false"/>

        <include file="../objects/kitchen2_body.xml"/>

		<body name="floor">
            <geom contype="1" conaffinity="2" friction=".1 0.005 0.0001" name="floor" pos="2.75 -2.3 0" size="3 2.5 .25" type="plane" material="floor_room_wall_mat" condim="3" solimp="0 0.95 0.001 0.5 2" solref="0.02 1" margin="0"/>
		</body>

        <body name="reachy" pos="0.85 -1.1 0" euler="0 0 1.57">
            <freejoint name="mobile_base" />
            <include file="../objects/reachy2_body.xml"/>
        </body>

        <body name="table" pos="2 -2.5 0" euler="1.57 0 0">
            <geom class = "ycb_viz" name="table_visual"  mesh="wooden_table" material="wooden_table_material"/>
            <geom class = "ycb_col" name="table_collision" type="box" size="0.45 0.34 0.28" pos="0 0.3 0" margin = "0" friction="1 0.005 0.0005" solref="0.03 1" solimp="0.99 0.99 0.01"/>
        </body>

        <body name="fork" pos="1.7 -2.35 0.7" euler="0 0 -1.57">
            <freejoint name="fork" />
            <include file="../objects/fork_body.xml"/>
        </body>
        <body name="knife" pos="1.7 -2.65 0.7" euler="0 0 -1.57">
            <freejoint name="knife" />
            <include file="../objects/knife_body.xml"/>
        </body>

        <body name = "plate" pos="1.7 -2.5 0.7" euler="0 0 0">
            <freejoint name="plate"/>
			<include file="../objects/plate_body.xml" />
		</body>

        <body name = "cup" pos="0.5 -0.5 0.8" euler="0 0 0"> 
        <!-- pos="3.7 -0.37 1.47" sur l'étgère -->
        <!-- pos="2.52 -0.45 0.53" dans le tiroir -->
        <!-- pos="2.25 -0.55 0.965" sur le comptoir -->
         <!-- pos="1.9 -2.5 0.7" sur la table -->
            <freejoint name="cup"/>
            <include file="../objects/cup_body.xml" />
        </body>
    </worldbody>
</mujoco>
